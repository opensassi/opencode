{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "skill-manager": "allow",
    "system-design": "allow",
    "system-design-review": "allow",
    "session-evaluation": "allow",
    "git": "allow",
    "opensassi": "allow",
    "profiler": "allow",
    "issue": "allow",
    "asm-optimizer": "allow",
    "todo": "allow",
    "daily-evaluation": "allow",
    "npm-optimizer": "allow"
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--headless"],
      "enabled": true
    },
    "debugger": {
      "type": "local",
      "command": ["gdb-mcp-server"],
      "enabled": true
    }
  }
}
